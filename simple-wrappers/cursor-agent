#!/usr/bin/env sh

_self="$0"
[ -L "$_self" ] && _self="$(readlink "$_self")"
AGENTS_STATUS_DIR="$(cd "$(dirname "$_self")/../core" && pwd)"

( . "$AGENTS_STATUS_DIR/helpers.sh"
  ensure_server
  send_event cursor IDLE ) >/dev/null 2>&1

BIN="${CURSOR_CLI_WRAPPER_BIN:-cursor-cli-wrapper}"
"$BIN" "$@"
