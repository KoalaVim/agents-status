#!/usr/bin/env sh

input=$(cat 2>/dev/null)

(
    export CLAUDE_TRANSCRIPT_PATH="$(printf '%s' "$input" | grep -o '"transcript_path"[[:space:]]*:[[:space:]]*"[^"]*"' | sed 's/.*"\([^"]*\)"$/\1/')"
    AGENTS_STATUS_DIR="$(cd "$(dirname "$0")/../../core" && pwd)"
    . "$AGENTS_STATUS_DIR/helpers.sh"
    ensure_server
    send_event claude IDLE
) </dev/null >/dev/null 2>&1 &
