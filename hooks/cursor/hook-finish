#!/usr/bin/env sh

input=$(cat 2>/dev/null)

(
    export CURSOR_CONVERSATION_ID="$(printf '%s' "$input" | grep -o '"conversation_id"[[:space:]]*:[[:space:]]*"[^"]*"' | sed 's/.*"\([^"]*\)"$/\1/')"
    _dir="$(cd "$(dirname "$0")/../../core" && pwd)"
    . "$_dir/helpers.sh"
    send_event cursor DONE Done "" ""
) </dev/null >/dev/null 2>&1 &
